# ──────────────────────────────────────────────
# GranWatch — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Clerk (auth) ──────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Set this after your first login in production:
# it's the Clerk userId of the app owner (Konstand).
OWNER_CLERK_ID=

# ── Database (MySQL on Railway) ────────────────
# Copy from Railway → your MySQL service → Variables tab.
DATABASE_URL=mysql://user:password@host:3306/dbname

# ── Cloudflare R2 (file storage) ──────────────
# Create an R2 bucket named "granwatch-media" in Cloudflare.
# Then generate API tokens under R2 → Manage R2 API tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=granwatch-media

# ── Resend (transactional email) ───────────────
# Get your API key from https://resend.com/api-keys
# Add DNS records for granwatch.app in Cloudflare.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@granwatch.app

# ── Payfast (South African payments) ──────────
# https://developers.payfast.co.za
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# ── Lemon Squeezy (payments) ──────────────────
# API key: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
# Store ID: Better Creation store
LS_STORE_ID=354262
# Variant ID: Gran+ monthly
LS_VARIANT_ID=1681701
# Webhook signing secret
LEMONSQUEEZY_WEBHOOK_SECRET=gw_ls_wh_k9X2mP4nQ8vR3jT7yF5bN1cL6eA0dH

# ── OpenAI (LLM / AI features) ────────────────
# Optional — only needed if you use AI summaries or voice transcription.
OPENAI_API_KEY=

# ── App ───────────────────────────────────────
NODE_ENV=development
PORT=3000
