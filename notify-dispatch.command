#!/bin/zsh
# Fires a macOS notification (relayed to iPhone via Dispatch).
osascript -e 'display notification "Profile + Care + Gran+ code all deployed live — no terminal needed from you. To switch ON Gran+ subscriptions: ~15 min of App Store Connect + RevenueCat dashboard setup (see GRANPLUS-IAP-SETUP.md). No new build needed. Tell Claude when ready and it will guide you + wire the keys, then you sandbox-test on Build 7." with title "GranWatch · Claude" sound name "Glass"'
