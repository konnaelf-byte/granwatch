# GranWatch — fastlane config
# One-command TestFlight builds. Run from repo root:  fastlane beta
# Requires App Store Connect API key (see FASTER-BUILDS.md) via env vars:
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_PATH  (path to the AuthKey_XXXX.p8)
#
# Tip: run `pnpm run cap:build` BEFORE `fastlane beta` so the web bundle is synced into iOS.

default_platform(:ios)

APP_IDENTIFIER = "app.granwatch"
WORKSPACE = "ios/App/App.xcworkspace"
SCHEME = "App"

platform :ios do
  desc "Build and upload to TestFlight (App Store Connect API key auth — no 2FA)"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false
    )

    # Set build number to (latest TestFlight build + 1) so it's always unique.
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 7
    )
    increment_build_number(
      xcodeproj: "ios/App/App.xcodeproj",
      build_number: (latest + 1).to_s
    )

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "build",
      clean: true
      # If manual signing needs explicit mapping, add:
      # export_options: { provisioningProfiles: {
      #   "app.granwatch" => "GranWatch Distribution",
      #   "app.granwatch.widget" => "GranWatch Widget Distribution" } }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )

    UI.success("✅ Uploaded to TestFlight. It'll appear on the Internal track after processing (~minutes).")
  end

  desc "Upload an already-built IPA without rebuilding (point IPA_PATH at the .ipa)"
  lane :upload_only do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER_ID"], key_filepath: ENV["ASC_KEY_PATH"]
    )
    upload_to_testflight(api_key: api_key, ipa: ENV["IPA_PATH"], skip_waiting_for_build_processing: true)
  end
end
